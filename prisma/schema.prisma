generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model ExchangeConfig {
  id         String     @id @default(cuid())
  name       String
  label      String
  apiKey     String
  apiSecret  String
  sandbox    Boolean    @default(true)
  createdAt  DateTime   @default(now())
  strategies Strategy[]
  trades     Trade[]
}

model Strategy {
  id         String           @id @default(cuid())
  name       String
  type       String
  symbol     String
  timeframe  String
  config     String
  status     String           @default("stopped")
  exchangeId String
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt
  backtests  BacktestResult[]
  exchange   ExchangeConfig   @relation(fields: [exchangeId], references: [id])
  trades     Trade[]
}

model Trade {
  id         String         @id @default(cuid())
  exchangeId String
  strategyId String?
  symbol     String
  side       String
  type       String
  quantity   Float
  price      Float
  fee        Float          @default(0)
  pnl        Float?
  orderId    String
  status     String
  openedAt   DateTime       @default(now())
  closedAt   DateTime?
  strategy   Strategy?      @relation(fields: [strategyId], references: [id])
  exchange   ExchangeConfig @relation(fields: [exchangeId], references: [id])
}

model BacktestResult {
  id              String   @id @default(cuid())
  strategyId      String
  symbol          String
  timeframe       String
  startDate       DateTime
  endDate         DateTime
  initialCapital  Float
  finalCapital    Float
  totalTrades     Int
  winRate         Float
  sharpeRatio     Float
  maxDrawdown     Float
  profitFactor    Float
  tradesJson      String
  equityCurveJson String
  createdAt       DateTime @default(now())
  strategy        Strategy @relation(fields: [strategyId], references: [id])
}

model SystemLog {
  id        String   @id @default(cuid())
  level     String
  source    String
  message   String
  meta      String?
  createdAt DateTime @default(now())

  @@index([level])
  @@index([createdAt])
}

model ModelMemory {
  id          String   @id @default(cuid())
  symbol      String
  timeframe   String
  memoryJson  String
  candleCount Int
  trainedAt   DateTime @default(now())

  @@unique([symbol, timeframe])
}

model RiskProfile {
  id                   String @id @default(cuid())
  maxPositionSizePct   Float  @default(5.0)
  maxDrawdownPct       Float  @default(20.0)
  defaultStopLossPct   Float  @default(2.0)
  defaultTakeProfitPct Float  @default(4.0)
  maxOpenPositions     Int    @default(5)
}
